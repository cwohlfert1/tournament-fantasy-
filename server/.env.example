JWT_SECRET=your_jwt_secret_here
GIPHY_API_KEY=your_giphy_api_key_here
CLIENT_URL=http://localhost:5173
PORT=3001

# ── Square Payments ───────────────────────────────────────────────────────────
# Get these from Square Developer Console → Applications → your app
SQUARE_ACCESS_TOKEN=your_square_access_token_here
SQUARE_APPLICATION_ID=your_square_app_id_here
SQUARE_LOCATION_ID=your_square_location_id_here
# 'sandbox' for testing, 'production' for live
SQUARE_ENVIRONMENT=sandbox

# Square webhook signature keys — set these after registering webhooks in
# Square Developer Console → Webhooks. Each endpoint gets its own key.
# Subscribe to: payment.completed
SQUARE_WEBHOOK_SIGNATURE_KEY=your_square_webhook_signature_key_here
# Full URL Square sends to (must match exactly what is registered in Square Console):
SQUARE_WEBHOOK_URL=https://your-server.railway.app/api/payments/webhook
# Optional: separate signature key for the golf webhook endpoint
# SQUARE_GOLF_WEBHOOK_URL=https://your-server.railway.app/api/golf/webhooks/stripe

# ── DataGolf API (Scratch Plus) ───────────────────────────────────────────────
# Get from https://datagolf.com/api-access → Your API Keys
# Rate limit: 45 req/min. Powers field sync, player IDs, schedule, and live SG stats.
DATAGOLF_API_KEY=your_datagolf_api_key_here
